# ─────────────────────────────────────────────────────────────
# RAISA — Archivo de entorno (.env)
# NUNCA subir este archivo a control de versiones.
# Copiar como .env y rellenar los valores reales.
# ─────────────────────────────────────────────────────────────

# Token del bot de Discord
DISCORD_TOKEN=TU_TOKEN_AQUI

# IDs de usuario con acceso total (sin comillas)
OWNER_ID=000000000000000000
HOLDER_ID=000000000000000000

# Clave para el modo SUDO (autenticación por MD para acciones críticas)
SUDO_KEY=clave_sudo_muy_segura

# ID del canal al que llegan las fichas para verificación
CANAL_VERIFICACION_ID=000000000000000000

# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
